{
  "manifest_version": 3,
  "name": "Linux.do SidePeek",
  "version": "0.1.0",
  "description": "Preview Linux.do topics in a right-side drawer without leaving the topic list.",
  "host_permissions": [
    "https://linux.do/t/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://linux.do/",
        "https://linux.do/latest*",
        "https://linux.do/new*",
        "https://linux.do/unread*",
        "https://linux.do/top*",
        "https://linux.do/hot*",
        "https://linux.do/c/*",
        "https://linux.do/tag/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
